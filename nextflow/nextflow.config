// ── Default parameters (mirrors config.yaml) ──────────────────────────────
params {
    // Sample list; leave empty [] to auto-discover *.bam in bam_dir
    samples          = []
    bam_dir          = "."

    // Tool paths
    scriptsdir       = "${projectDir}/scripts"
    kraken_db        = "/sc/arion/projects/schzrnas/zhangy40/softwares/kuniq_microbialdb_minus_kdb.20230808"
    blastdb          = "/hpc/users/zhangy40/schzrnas/softwares/blast_db/nt"
    t2t_ref          = "/sc/arion/projects/schzrnas/zhangy40/ref/CHM13_T2T/chm13v2.0.mmi"

    // BLAST splitting
    blast_split_nseq = 5000

    // Output directory
    outdir           = "results"

    // LSF billing project
    lsf_project      = "acc_schzrnas"

    // Scratch directory for I/O-heavy intermediate steps.
    // Override at runtime: --scratch_dir /other/path
    scratch_dir      = "/sc/arion/scratch/zhangy40"
}

// ── Per-process resource configuration (mirrors cluster.yaml) ─────────────
process {
    // Global defaults
    executor       = 'lsf'
    queue          = 'premium'
    time           = '6h'
    memory         = '8 GB'
    cpus           = 1
    clusterOptions = { "-P ${params.lsf_project}" }

    // unmapped_analysis
    withName: 'UNMAPPED_ANALYSIS' {
        cpus   = 10
        memory = '12 GB'
        time   = '4h'
    }

    // mapped_human_stats
    withName: 'MAPPED_HUMAN_STATS' {
        cpus   = 10
        memory = '6 GB'
        time   = '6h'
    }

    // krakenuniq  – requires high-memory node
    withName: 'KRAKENUNIQ' {
        cpus           = 4
        memory         = '150 GB'
        time           = '12h'
        maxForks       = 5
        clusterOptions = { "-P ${params.lsf_project} -R himem" }
    }

    withName: 'KRAKEN_PROCESS' {
        cpus      = 1
        memory    = '8 GB'
        time      = '2h'
        maxForks  = 20
    }

    withName: 'SPLIT_BLAST_QUERY' {
        cpus    = 1
        memory  = '8 GB'
        time    = '1h'
        scratch = { params.scratch_dir }
    }

    // megaBLAST per chunk – requires high-memory node
    withName: 'MEGABLAST_CHUNK' {
        cpus           = 8
        memory         = '30 GB'
        time           = '6h'
        scratch        = { params.scratch_dir }
        clusterOptions = { "-P ${params.lsf_project} -R himem" }
    }

    withName: 'MERGE_BLAST_CHUNKS' {
        cpus   = 1
        memory = '4 GB'
        time   = '1h'
        queue  = 'express'
    }

    withName: 'PROCESS_BLAST' {
        cpus   = 10
        memory = '30 GB'
        time   = '2h'
        queue  = 'express'
    }

    withName: 'ANNOTATE_BLAST_LENGTHS' {
        cpus   = 1
        memory = '30 GB'
        time   = '2h'
        queue  = 'express'
    }

    withName: 'MEDIAN_LENGTH_ADJ' {
        cpus   = 1
        memory = '8 GB'
        time   = '2h'
    }
}

// ── Execution profiles ────────────────────────────────────────────────────
profiles {
    // Default: submit to LSF (Minerva / similar HPC)
    lsf {
        process.executor = 'lsf'
    }

    // Local execution for testing (single machine)
    local {
        process.executor = 'local'
        process.cpus     = 4
        process.memory   = '8 GB'
        process.queue    = null
        process.clusterOptions = null
    }

    // Singularity container (can be combined with lsf or local)
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = 'pipeline.sif'
    }
}

// ── Nextflow execution settings ───────────────────────────────────────────
executor {
    // Max simultaneous jobs submitted to the scheduler
    queueSize = 200
}

// Keep intermediate files for debugging; remove for production runs
// cleanup = true
